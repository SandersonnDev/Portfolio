---
import Layout from "../layouts/Layout.astro";
import { site } from "../data/portfolio";
---

<Layout pageTitle="CV" description={`Curriculum vitae — ${site.tagline}`}>
	<div class="mx-auto max-w-3xl px-4 py-16 sm:px-6 lg:px-10" transition:name="main-content" transition:animate="slide">
		<header class="border-b border-indigo-400/20 pb-10 dark:border-indigo-400/15">
			<p class="text-sm font-medium uppercase tracking-wider text-indigo-600 dark:text-indigo-400">Curriculum vitae</p>
			<h1 class="mt-2 text-3xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100 sm:text-4xl">{site.name}</h1>
			<p class="mt-3 text-lg text-zinc-600 dark:text-zinc-400">{site.tagline}</p>
			<div class="mt-6 flex flex-wrap gap-3 text-sm">
				<a
					href={`mailto:${site.email}`}
					class="inline-flex items-center gap-2 text-indigo-700 transition-ui hover:text-indigo-900 dark:text-indigo-400 dark:hover:text-indigo-300"
				>
					<i class="fa-solid fa-envelope" aria-hidden="true"></i>
					{site.email}
				</a>
			</div>
		</header>

		<div class="mt-12 space-y-14 text-zinc-700 dark:text-zinc-300">
			<section aria-labelledby="cv-profile-heading">
				<h2 id="cv-profile-heading" class="text-lg font-semibold text-zinc-900 dark:text-zinc-100">Profil</h2>
				<p class="mt-4 leading-relaxed">
					Développeur web et applications : conception d’interfaces, intégration, APIs et mise en production. À compléter avec
					votre parcours et vos objectifs professionnels.
				</p>
			</section>

			<section aria-labelledby="cv-exp-heading">
				<h2 id="cv-exp-heading" class="text-lg font-semibold text-zinc-900 dark:text-zinc-100">Expérience</h2>
				<ul class="mt-6 space-y-8">
					<li>
						<p class="text-sm font-medium text-indigo-600 dark:text-indigo-400">20XX — présent · Poste</p>
						<p class="mt-1 font-medium text-zinc-900 dark:text-zinc-100">Entreprise ou contexte</p>
						<p class="mt-2 text-sm leading-relaxed">
							Description des missions, stack utilisée et résultats. Remplacez ce bloc par vos expériences réelles.
						</p>
					</li>
				</ul>
			</section>

			<section aria-labelledby="cv-edu-heading">
				<h2 id="cv-edu-heading" class="text-lg font-semibold text-zinc-900 dark:text-zinc-100">Formation</h2>
				<ul class="mt-6 space-y-4 text-sm leading-relaxed">
					<li>
						<span class="font-medium text-zinc-900 dark:text-zinc-100">Diplôme ou certification</span>
						<span class="text-zinc-500 dark:text-zinc-500"> — Établissement, année</span>
					</li>
				</ul>
			</section>

			<section aria-labelledby="cv-skills-heading">
				<h2 id="cv-skills-heading" class="text-lg font-semibold text-zinc-900 dark:text-zinc-100">Compétences</h2>
				<p class="mt-4 text-sm leading-relaxed">
					Ex. HTML, CSS, JavaScript, frameworks front, back-end, bases de données, Git, méthodes agiles — adaptez la liste à votre
					profil.
				</p>
			</section>

			<section aria-labelledby="cv-lang-heading">
				<h2 id="cv-lang-heading" class="text-lg font-semibold text-zinc-900 dark:text-zinc-100">Langues</h2>
				<ul class="mt-4 list-inside list-disc text-sm">
					<li>Français — langue maternelle</li>
					<li>Anglais — à préciser (niveau CECRL)</li>
				</ul>
			</section>
		</div>

		<a
			href="/"
			class="mt-14 inline-flex items-center gap-2 text-sm font-medium text-indigo-700 transition-ui hover:text-indigo-900 dark:text-indigo-400 dark:hover:text-indigo-300"
		>
			<i class="fa-solid fa-arrow-left text-xs" aria-hidden="true"></i>
			Retour à l’accueil
		</a>
	</div>
</Layout>

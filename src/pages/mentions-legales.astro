---
import Layout from "../layouts/Layout.astro";
import { site } from "../site.config";
---

<Layout title={`Mentions légales · ${site.displayName}`}>
	<main class="mx-auto max-w-3xl px-5 py-32 md:px-8">
		<h1 class="text-3xl font-normal tracking-tight md:text-4xl">Mentions légales</h1>
		<p class="mt-8 text-(--fg-dim) leading-relaxed">
			Complétez cette page avec les informations légales obligatoires pour votre situation
			(éditeur, hébergeur, contact, propriété intellectuelle).
		</p>
		<p class="mt-4 text-(--fg-dim) leading-relaxed">
			Site : <span class="text-(--fg)">{site.displayName}</span>
		</p>
	</main>
</Layout>

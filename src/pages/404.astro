---
import Layout from "../layouts/Layout.astro";
import { site } from "../site.config";
import { withBase } from "../lib/paths";
---

<Layout title={`Signal perdu · ${site.displayName}`} description="404">
	<main class="flex min-h-[75dvh] flex-col items-center justify-center px-6 text-center">
		<p class="sys-mono text-[10px] tracking-[0.5em] text-(--accent)">404</p>
		<h1 class="font-display mt-6 text-3xl font-light tracking-[0.15em] text-(--fg) md:text-4xl">HORS GRILLE</h1>
		<p class="mt-4 max-w-sm text-sm leading-normal text-(--fg-dim)">Aucune ressource à ces coordonnées.</p>
		<a href={withBase("")} class="mt-12 btn-sys">Revenir au vaisseau</a>
	</main>
</Layout>

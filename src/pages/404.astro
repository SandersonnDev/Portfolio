---
import "../styles/global.css"
import Layout404 from "../layouts/Layout404.astro"
---
<Layout404 >
	
<main class="flex flex-1 flex-col items-center justify-center bg-gray-900 px-6 py-24 sm:py-32 lg:px-8">
  <div class="text-center">
	<p class="text-4xl sm:text-6xl font-semibold text-indigo-400">404</p>
	<h1 class="mt-4 text-5xl font-semibold tracking-tight text-balance text-white sm:text-7xl">Page introuvable</h1>
	<p class="mt-6 text-lg font-medium text-pretty text-gray-400 sm:text-xl/8">Désolé, nous n'avons pas trouvé la page que vous recherchez.</p>
	<div class="mt-10 flex items-center justify-center gap-x-6">
	  <a href="/" class="rounded-md bg-indigo-500 px-3.5 py-2.5 text-sm font-semibold text-white shadow-xs hover:bg-indigo-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-500">
	  Retournez a l'accueil</a>
	</div>
  </div>
</main>

</Layout404>
---
import Layout from "../layouts/Layout.astro";
import { withBase } from "../lib/paths";
---


<Layout>
	<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 flex flex-col items-center justify-center text-sm h-[400px]">
		<p class="font-medium text-lg text-indigo-500">404 Error</p>
		<h2 class="md:text-6xl text-4xl font-semibold text-gray-300 ">Page Not Found</h2>
		<p class="text-base mt-4 text-gray-300">Sorry, we couldn’t find the page you’re looking for.</p>
		<div class="flex items-center gap-4 mt-6">
			<button type="button" class="bg-indigo-500 hover:bg-indigo-600 px-7 py-2.5 text-white rounded active:scale-95 transition-all">
				<a href={withBase("#home")}>Go back home</a>
			</button>
		</div>
	</div>
</Layout>
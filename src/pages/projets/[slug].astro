---
import Layout from "../../layouts/Layout.astro";
import { site, copy } from "../../site.config";
import { withBase } from "../../lib/paths";
import gh from "../../data/github-projects.generated.json";
import ReadmeBlocks from "../../components/ReadmeBlocks.astro";
import ProjectArticleNav from "../../components/ProjectArticleNav.astro";
import type { ReadmeBlock } from "../../types/readme-blocks";

type Project = {
	slug: string;
	title: string;
	description: string;
	href: string;
	liveHref: string | null;
	stack: string[];
	sections: ReadmeBlock[];
	coverImage?: string | null;
};

export function getStaticPaths() {
	const projects = gh.projects as Project[];
	return projects.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const projects = gh.projects as Project[];
const project = projects.find((p) => p.slug === slug);

if (!project) throw new Error(`Projet inconnu : ${slug}`);

const title = `${project.title} · ${site.displayName}`;
const repoPath = project.href.replace(/^https?:\/\/(www\.)?github\.com\//i, "");
const contentBlocks = (project.sections ?? []) as ReadmeBlock[];
const idx = projects.findIndex((p) => p.slug === slug);
const prev = idx > 0 ? projects[idx - 1]! : null;
const next = idx >= 0 && idx < projects.length - 1 ? projects[idx + 1]! : null;
---

<Layout title={title} description={project.description}>
	<article class="mx-auto max-w-5xl px-5 pb-28 pt-20 project-page md:px-12 md:pt-24">
		<a
			href={withBase("#projects")}
			class="project-page__back"
			title={copy.projectBackTitle}
			aria-label={copy.projectBackTitle}
		>
			<i class="fa-solid fa-arrow-left-long" aria-hidden="true"></i>
			{copy.projectBackLabel}
		</a>

		{
			prev || next ? (
				<div class="mt-6 flex flex-wrap items-center justify-between gap-3 project-page__jump md:gap-4">
					{prev ? (
						<a
							href={withBase(`projets/${prev.slug}`)}
							class="project-page__jump-link project-page__jump-link--prev"
							data-project-nav="prev"
						>
							<span class="project-page__jump-arrow" aria-hidden="true">←</span>
							<span class="project-page__jump-title">{prev.title}</span>
						</a>
					) : (
						<span />
					)}
					{next ? (
						<a
							href={withBase(`projets/${next.slug}`)}
							class="project-page__jump-link project-page__jump-link--next"
							data-project-nav="next"
						>
							<span class="project-page__jump-title">{next.title}</span>
							<span class="project-page__jump-arrow" aria-hidden="true">→</span>
						</a>
					) : (
						<span />
					)}
				</div>
			) : null
		}

		<p class="mt-10 sys-mono text-[10px] tracking-[0.22em] project-page__repo">
			<a
				href={project.href}
				target="_blank"
				rel="noopener noreferrer"
				class="text-(--accent) transition-opacity hover:opacity-90"
				title={copy.tileTitleGithub(project.title)}
			>
				<span class="text-(--fg-dim)">GitHub · </span>{repoPath}
			</a>
		</p>

		<div
			class="mt-6 grid gap-10 project-page__hero lg:grid-cols-[minmax(0,1fr)_min(100%,17.5rem)] lg:items-start lg:gap-14 xl:grid-cols-[minmax(0,1fr)_19.5rem]"
		>
			<div class="min-w-0">
				<h1 class="text-3xl article-title md:text-4xl lg:text-[2.35rem]" aria-label={project.title}>
					<span data-scramble data-scramble-final={project.title} class="inline-block min-h-[1.2em]"></span>
				</h1>
				<p class="mt-6 min-h-16 text-base leading-relaxed text-(--fg-dim) project-page__lead tw-paragraph md:text-lg">
					{project.description}
				</p>
			</div>

			<aside class="flex min-w-0 flex-col gap-5 project-page__aside lg:sticky lg:top-24 lg:self-start">
				<div class="rounded-xl p-6 glass glass--panel md:p-7">
					<p class="about-block__label mb-0">{copy.projectDetailLinks}</p>
					<div class="mt-5 flex flex-col gap-3">
						<a
							href={project.href}
							target="_blank"
							rel="noopener noreferrer"
							class="btn-sys justify-center"
							title={copy.tileTitleGithub(project.title)}
						>
							<i class="fa-brands fa-github mr-2" aria-hidden="true"></i>
							Dépôt
						</a>
						{
							project.liveHref ? (
								<a
									href={project.liveHref}
									target="_blank"
									rel="noopener noreferrer"
									class="btn-sys btn-sys--muted justify-center"
									title="Ouvrir la démo dans un nouvel onglet"
								>
									<i class="fa-solid fa-globe mr-2" aria-hidden="true"></i>
									Démo
								</a>
							) : null
						}
					</div>
				</div>

				{
					project.stack?.length ? (
						<div class="rounded-xl p-6 glass glass--panel md:p-7">
							<p class="about-block__label mb-0">{copy.projectDetailTech}</p>
							<ul
								id="project-stack-tags"
								class="about-stack-tags mt-5 flex flex-wrap gap-2"
								aria-label={copy.projectDetailTech}
							>
								{project.stack.map((t) => (
									<li>
										<span class="chip">{t}</span>
									</li>
								))}
							</ul>
						</div>
					) : null
				}
			</aside>
		</div>

		{
			project.coverImage ? (
				<div
					class="mt-12 overflow-hidden rounded-xl border border-[color-mix(in_srgb,var(--accent)_14%,transparent)] project-page__cover"
				>
					<img
						src={project.coverImage}
						alt=""
						class="h-auto w-full object-cover"
						loading="lazy"
						decoding="async"
					/>
				</div>
			) : null
		}

		{
			contentBlocks.length ? (
				<div class="project-page__journal-clip">
					<section class="mt-16 project-page__journal md:mt-20" aria-labelledby="project-journal-h">
						<h2 id="project-journal-h" class="display-heading display-heading--lg">
							{copy.projectJournalHeading}
						</h2>
						<div class="mt-10 project-page__readme">
							<ReadmeBlocks blocks={contentBlocks} />
						</div>
					</section>
				</div>
			) : null
		}

		<ProjectArticleNav
			prev={prev ? { slug: prev.slug, title: prev.title } : null}
			next={next ? { slug: next.slug, title: next.title } : null}
		/>
	</article>
</Layout>

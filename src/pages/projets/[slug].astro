---
import Layout from "../../layouts/Layout.astro";
import ProjectCard from "../../components/portfolio/ProjectCard.astro";
import { projects, type Project, type ProjectSection } from "../../data/portfolio";

export function getStaticPaths() {
	return projects.map((project) => ({
		params: { slug: project.slug },
		props: { project },
	}));
}

interface Props {
	project: Project;
}

const { project } = Astro.props;

type ImgSection = Extract<ProjectSection, { type: "image" }>;
type BlockGroup =
	| { kind: "block"; section: ProjectSection }
	| { kind: "images"; items: ImgSection[] };

function groupSections(sections: ProjectSection[]): BlockGroup[] {
	const out: BlockGroup[] = [];
	let buf: ImgSection[] = [];
	for (const s of sections) {
		if (s.type === "image") {
			buf.push(s);
		} else {
			if (buf.length) {
				out.push({ kind: "images", items: buf });
				buf = [];
			}
			out.push({ kind: "block", section: s });
		}
	}
	if (buf.length) out.push({ kind: "images", items: buf });
	return out;
}

const grouped = groupSections(project.sections);

function embedSrc(url: string | undefined): string {
	if (!url?.trim()) return "";
	try {
		if (url.includes("youtu.be/")) {
			const id = url.split("youtu.be/")[1]?.split(/[?#]/)[0];
			return id ? `https://www.youtube.com/embed/${id}` : url;
		}
		if (url.includes("youtube.com/watch")) {
			const id = new URL(url).searchParams.get("v");
			return id ? `https://www.youtube.com/embed/${id}` : url;
		}
		if (url.includes("youtube.com/embed")) {
			return url;
		}
		if (url.includes("vimeo.com/") && !url.includes("player.vimeo")) {
			const id = url.split("vimeo.com/")[1]?.split(/[?#]/)[0];
			return id ? `https://player.vimeo.com/video/${id}` : url;
		}
		return url;
	} catch {
		return url;
	}
}

const pageDescription = project.description;
---

<Layout pageTitle={project.title} description={pageDescription}>
	<article
		class="mx-auto max-w-3xl px-4 py-16 text-zinc-900 sm:px-6 sm:py-20 lg:max-w-4xl lg:px-10 dark:text-zinc-100"
		transition:name="main-content"
		transition:animate="slide"
	>
		<nav class="mb-8 text-sm" aria-label="Fil d’Ariane">
			<a
				href="/#projects"
				class="text-zinc-600 transition-ui hover:text-indigo-700 dark:text-zinc-500 dark:hover:text-indigo-400"
			>
				← Projets
			</a>
		</nav>

		<header class="mb-12 max-w-2xl">
			<h1 class="text-3xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100 md:text-4xl">{project.title}</h1>
			<p class="mt-5 text-lg leading-relaxed text-zinc-600 dark:text-zinc-400 md:text-xl">{project.description}</p>
			<div class="mt-6 flex flex-wrap gap-2">
				{project.stack.map((t) => (
					<span class="rounded-md bg-zinc-200 px-2.5 py-1 text-xs font-medium text-zinc-700 dark:bg-zinc-800 dark:text-zinc-300">
						{t}
					</span>
				))}
			</div>
			<div class="mt-8 flex flex-wrap gap-3">
				<a
					href={project.href}
					target="_blank"
					rel="noopener noreferrer"
					class="text-on-indigo-btn neon-border transition-ui inline-flex items-center gap-2 rounded-md border border-indigo-500/45 bg-indigo-700 px-4 py-2.5 text-sm font-medium hover:border-indigo-400/60 hover:bg-indigo-600 dark:border-indigo-400/35 dark:bg-indigo-950 dark:hover:border-indigo-400/55 dark:hover:bg-indigo-900"
				>
					<i class="fa-brands fa-github text-on-indigo-btn" aria-hidden="true"></i>
					Code source
				</a>
				{
					project.liveHref && (
						<a
							href={project.liveHref}
							target="_blank"
							rel="noopener noreferrer"
							class="transition-ui inline-flex items-center gap-2 rounded-md border border-zinc-400 bg-zinc-200 px-4 py-2.5 text-sm font-medium text-zinc-900 hover:border-indigo-500/45 hover:bg-zinc-300 dark:border-zinc-600 dark:bg-zinc-900 dark:text-zinc-200 dark:hover:border-indigo-400/45 dark:hover:bg-zinc-800"
						>
							<i class="fa-solid fa-arrow-up-right-from-square text-xs" aria-hidden="true" />
							Voir en ligne
						</a>
					)
				}
			</div>
		</header>

		<div class="space-y-14">
			{
				grouped.map((g) => {
					if (g.kind === "block") {
						const section = g.section;
						if (section.type === "paragraph") {
							return (
								<p class="max-w-2xl text-base leading-[1.75] text-zinc-700 dark:text-zinc-300 md:text-lg">
									{section.text}
								</p>
							);
						}
						if (section.type === "video") {
							const embed = embedSrc(section.embedUrl);
							const hasMp4 = Boolean(section.mp4Url?.trim());
							const hasEmbed = Boolean(embed);
							const showPlaceholder = !hasEmbed && !hasMp4;
							return (
								<figure class="overflow-hidden rounded-xl bg-zinc-200 dark:bg-zinc-900">
									{hasEmbed && (
										<div class="aspect-video w-full bg-black">
											<iframe
												src={embed}
												class="h-full w-full"
												title={section.caption || "Vidéo du projet"}
												allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
												allowfullscreen
											/>
										</div>
									)}
									{!hasEmbed && hasMp4 && (
										<video class="aspect-video w-full bg-black object-contain" controls preload="metadata">
											<source src={section.mp4Url} type="video/mp4" />
											Votre navigateur ne lit pas la vidéo HTML5.
										</video>
									)}
									{showPlaceholder && (
										<div class="flex aspect-video w-full flex-col items-center justify-center gap-3 bg-zinc-100 px-6 dark:bg-zinc-950">
											<i class="fa-solid fa-film text-4xl text-indigo-500/50 dark:text-indigo-400/45" aria-hidden="true" />
											<p class="px-4 text-center text-sm text-zinc-600 dark:text-zinc-500">
												{section.caption || "Ajoutez embedUrl (YouTube/Vimeo) ou mp4Url dans les données du projet."}
											</p>
										</div>
									)}
									{section.caption && !showPlaceholder && (
										<figcaption class="px-4 pb-4 pt-3 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">
											{section.caption}
										</figcaption>
									)}
								</figure>
							);
						}
						return null;
					}

					const cols = g.items.length > 1 ? "project-img-grid cols-2" : "project-img-grid";
					return (
						<div class={cols}>
							{g.items.map((section) => {
								const hasSrc = Boolean(section.src?.trim());
								return (
									<figure class="overflow-hidden rounded-xl bg-zinc-200 dark:bg-zinc-900">
										{hasSrc ? (
											<button
												type="button"
												class="group w-full border-0 bg-transparent p-0 text-left"
												data-lightbox-open
												data-lightbox-src={section.src}
												data-lightbox-alt={section.alt}
											>
												<img
													src={section.src}
													alt={section.alt}
													class="project-img-trigger max-h-[min(70vh,560px)] w-full object-cover transition-opacity group-hover:opacity-95"
													loading="lazy"
												/>
											</button>
										) : (
											<div class="flex aspect-video w-full flex-col items-center justify-center gap-3 bg-zinc-100 px-6 py-16 dark:bg-zinc-950">
												<i class="fa-regular fa-image text-4xl text-indigo-500/45 dark:text-indigo-400/45" aria-hidden="true" />
												<p class="text-center text-sm text-zinc-600 dark:text-zinc-500">{section.alt}</p>
											</div>
										)}
										{section.caption && (
											<figcaption class="px-4 pb-4 pt-3 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">
												{section.caption}
											</figcaption>
										)}
									</figure>
								);
							})}
						</div>
					);
				})
			}
		</div>

		<section class="mt-20" aria-labelledby="project-carousel-heading">
			<h2 id="project-carousel-heading" class="mb-8 text-lg font-semibold tracking-tight text-zinc-900 dark:text-zinc-100">
				Tous les projets
			</h2>
			<div class="project-carousel" data-project-carousel>
				<button
					type="button"
					class="project-carousel-nav project-carousel-nav-prev"
					data-carousel-prev
					aria-label="Faire défiler les projets vers la gauche"
				>
					<i class="fa-solid fa-chevron-left text-sm" aria-hidden="true"></i>
				</button>
				<ul
					class="project-carousel-track"
					data-carousel-track
					role="list"
					aria-label="Liste des projets"
				>
					{
						projects.map((p) => (
							<li
								class="project-carousel-slide"
								{...(p.slug === project.slug ? { "data-carousel-current": "true" } : {})}
							>
								<ProjectCard project={p} highlight={p.slug === project.slug} cardLinkOverlay />
							</li>
						))
					}
				</ul>
				<button
					type="button"
					class="project-carousel-nav project-carousel-nav-next"
					data-carousel-next
					aria-label="Faire défiler les projets vers la droite"
				>
					<i class="fa-solid fa-chevron-right text-sm" aria-hidden="true"></i>
				</button>
			</div>
		</section>

		<a
			href="/#projects"
			class="neon-border mt-12 inline-flex items-center gap-2 rounded-md bg-zinc-200 px-4 py-2.5 text-sm font-medium text-zinc-900 transition-ui hover:bg-zinc-300 dark:bg-zinc-900 dark:text-zinc-200 dark:hover:bg-zinc-800"
		>
			<i class="fa-solid fa-arrow-left text-xs" aria-hidden="true" />
			Retour aux projets
		</a>
	</article>
</Layout>

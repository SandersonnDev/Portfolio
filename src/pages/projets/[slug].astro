---
import Layout from "../../layouts/Layout.astro";
import { site, copy } from "../../site.config";
import { withBase } from "../../lib/paths";
import gh from "../../data/github-projects.generated.json";
import ReadmeBlocks from "../../components/ReadmeBlocks.astro";
import ProjectArticleNav from "../../components/ProjectArticleNav.astro";
import type { ReadmeBlock } from "../../types/readme-blocks";

type Project = {
	slug: string;
	title: string;
	description: string;
	href: string;
	liveHref: string | null;
	stack: string[];
	sections: ReadmeBlock[];
	coverImage?: string | null;
};

export function getStaticPaths() {
	const projects = gh.projects as Project[];
	return projects.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const projects = gh.projects as Project[];
const project = projects.find((p) => p.slug === slug);

if (!project) throw new Error(`Projet inconnu : ${slug}`);

const title = `${project.title} · ${site.displayName}`;
const repoPath = project.href.replace(/^https?:\/\/(www\.)?github\.com\//i, "");
const contentBlocks = (project.sections ?? []) as ReadmeBlock[];
const idx = projects.findIndex((p) => p.slug === slug);
const prev = idx > 0 ? projects[idx - 1]! : null;
const next = idx >= 0 && idx < projects.length - 1 ? projects[idx + 1]! : null;
---

<Layout title={title} description={project.description}>
	<article
		class="project-page mx-auto max-w-5xl px-5 pb-28 pt-20 md:px-12 md:pt-24"
		transition:name="project-fiche"
	>
		<a
			href={withBase("#projects")}
			class="sys-mono inline-flex items-center gap-2 text-[10px] tracking-[0.25em] text-(--fg-dim) transition-colors hover:text-(--cyan)"
			title={copy.projectBackTitle}
			aria-label={copy.projectBackTitle}
		>
			<i class="fa-solid fa-arrow-left-long text-[10px]" aria-hidden="true"></i>
			{copy.projectBackLabel}
		</a>

		{
			prev || next ? (
				<div class="project-page__jump sys-mono mt-6 flex flex-wrap items-center justify-between gap-4 text-[10px] tracking-[0.18em]">
					{prev ? (
						<a
							href={withBase(`projets/${prev.slug}`)}
							class="max-w-[min(100%,16rem)] truncate text-(--fg-dim) transition-colors hover:text-(--cyan) md:max-w-[20rem]"
						>
							← {prev.title}
						</a>
					) : (
						<span />
					)}
					{next ? (
						<a
							href={withBase(`projets/${next.slug}`)}
							class="max-w-[min(100%,16rem)] truncate text-right text-(--fg-dim) transition-colors hover:text-(--cyan) md:max-w-[20rem]"
						>
							{next.title} →
						</a>
					) : (
						<span />
					)}
				</div>
			) : null
		}

		<p class="project-page__repo sys-mono mt-10 text-[10px] tracking-[0.22em]">
			<a
				href={project.href}
				target="_blank"
				rel="noopener noreferrer"
				class="text-(--cyan) transition-opacity hover:opacity-90"
				title={copy.tileTitleGithub(project.title)}
			>
				<span class="text-(--fg-dim)">GitHub · </span>{repoPath}
			</a>
		</p>

		<div
			class="project-page__hero mt-6 grid gap-10 lg:grid-cols-[minmax(0,1fr)_min(100%,17.5rem)] lg:items-start lg:gap-14 xl:grid-cols-[minmax(0,1fr)_19.5rem]"
		>
			<div class="min-w-0">
				<h1 class="article-title text-3xl md:text-4xl lg:text-[2.35rem]" aria-label={project.title}>
					<span data-scramble data-scramble-final={project.title} class="inline-block min-h-[1.2em]"></span>
				</h1>
				<p
					class="project-page__lead tw-paragraph mt-6 min-h-16 text-base leading-relaxed text-(--fg-dim) md:text-lg"
					data-typewriter
					data-tw-final={project.description}
					data-tw-speed="18"
				>
				</p>
			</div>

			<aside class="project-page__aside flex min-w-0 flex-col gap-5 lg:sticky lg:top-24 lg:self-start">
				<div class="glass glass--panel rounded-xl p-6 md:p-7">
					<p class="about-block__label mb-0">{copy.projectDetailLinks}</p>
					<div class="mt-5 flex flex-col gap-2.5">
						<a
							href={project.href}
							target="_blank"
							rel="noopener noreferrer"
							class="btn-sys btn-sys--sm justify-center"
							title={copy.tileTitleGithub(project.title)}
						>
							<i class="fa-brands fa-github mr-2" aria-hidden="true"></i>
							Dépôt
						</a>
						{
							project.liveHref ? (
								<a
									href={project.liveHref}
									target="_blank"
									rel="noopener noreferrer"
									class="btn-sys btn-sys--sm btn-sys--muted justify-center"
									title="Ouvrir la démo dans un nouvel onglet"
								>
									<i class="fa-solid fa-globe mr-2" aria-hidden="true"></i>
									Démo
								</a>
							) : null
						}
					</div>
				</div>

				{
					project.stack?.length ? (
						<div class="glass glass--panel rounded-xl p-6 md:p-7">
							<p class="about-block__label mb-0">{copy.projectDetailTech}</p>
							<ul class="mt-5 flex flex-wrap gap-2" aria-label={copy.projectDetailTech}>
								{project.stack.map((t) => (
									<li>
										<span class="chip">{t}</span>
									</li>
								))}
							</ul>
						</div>
					) : null
				}
			</aside>
		</div>

		{
			project.coverImage ? (
				<div class="project-page__cover mt-12 overflow-hidden rounded-xl border border-[color-mix(in_srgb,var(--cyan)_14%,transparent)]">
					<img
						src={project.coverImage}
						alt=""
						class="h-auto w-full object-cover"
						loading="lazy"
						decoding="async"
					/>
				</div>
			) : null
		}

		{
			contentBlocks.length ? (
				<section class="project-page__journal mt-16 md:mt-20" aria-labelledby="project-journal-h">
					<h2 id="project-journal-h" class="display-heading display-heading--lg">
						{copy.projectJournalHeading}
					</h2>
					<p class="project-page__journal-intro sys-mono mt-4 text-[10px] leading-relaxed tracking-[0.12em] text-(--fg-dim)">
						{copy.projectReadmeIntro}
					</p>
					<div class="project-page__readme mt-10">
						<ReadmeBlocks blocks={contentBlocks} />
					</div>
				</section>
			) : null
		}

		<ProjectArticleNav
			prev={prev ? { slug: prev.slug, title: prev.title } : null}
			next={next ? { slug: next.slug, title: next.title } : null}
		/>
	</article>
</Layout>

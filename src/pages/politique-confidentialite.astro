---
import Layout from "../layouts/Layout.astro";
import { site } from "../site.config";
---

<Layout title={`Politique de confidentialité · ${site.displayName}`}>
	<main class="mx-auto max-w-3xl px-5 py-32 md:px-8">
		<h1 class="text-3xl font-normal tracking-tight md:text-4xl">
			Politique de confidentialité
		</h1>
		<p class="mt-8 text-(--fg-dim) leading-relaxed">
			Décrivez ici les données collectées, leur finalité, la durée de conservation, les droits des
			utilisateurs (RGPD) et les cookies éventuels.
		</p>
		<p class="mt-4 text-(--fg-dim) leading-relaxed">
			Contact : <a href={`mailto:${site.email}`} class="link-underline text-(--fg)">{site.email}</a>
		</p>
	</main>
</Layout>

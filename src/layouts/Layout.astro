---
import "../styles/icons.css";
import "../styles/app.css";
import { info as infoEn } from "../site.ENconfig.ts";
import { info as infoFr } from "../site.FRconfig.ts";
import { withBase } from "../lib/paths";
import Navside from "../components/navside.astro";

interface Props {
	title?: string;
	description?: string;
}

const titleEn = Astro.props.title ?? `${infoEn.name}`;
const titleFr = Astro.props.title ?? `${infoFr.name}`;
const descriptionEn = Astro.props.description ?? infoEn.pitch;
const descriptionFr = Astro.props.description ?? infoFr.pitch;
---

<!doctype html>
<html
	lang="en"
	data-title-en={titleEn}
	data-title-fr={titleFr}
	data-description-en={descriptionEn}
	data-description-fr={descriptionFr}
>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<link rel="icon" type="image/svg+xml" href={withBase("favicon.svg")} />
		<meta name="description" content={descriptionEn} />
		<title>{titleEn}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Exo+2:wght@200;300;400;600&family=Share+Tech+Mono&display=optional"
			rel="stylesheet"
		/>
	</head>
	<body>
		<Navside />
		<slot />
		<script>
			import { boot } from "../scripts/client";
			boot();
		</script>
	</body>
</html>

---
import "../styles/icons.css";
import "../styles/app.css";
import { site } from "../site.config";
import Rail from "../components/Rail.astro";
import { withBase } from "../lib/paths";

interface Props {
	title?: string;
	description?: string;
}

const { title = `${site.displayName} · Portfolio`, description = site.pitch } = Astro.props;

const routePath = Astro.url.pathname;
function normalizePathname(p: string): string {
	const x = p.replace(/\/$/, "");
	return x === "" ? "/" : x;
}
const pathNorm = normalizePathname(routePath);
const baseNorm = import.meta.env.BASE_URL.replace(/\/$/, "") || "/";
const isHome = pathNorm === baseNorm;
/** Même logique que `transition-nav` : fiche projet seulement (évite un slide sur les autres routes). */
const isProjectDetailRoute = /\/projets\/[^/]+$/.test(pathNorm);
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<script is:inline>
			try {
				const k = "portfolio-theme:v1";
				const v = localStorage.getItem(k);
				document.documentElement.setAttribute("data-theme", v === "light" ? "light" : "dark");
			} catch (e) {
				document.documentElement.setAttribute("data-theme", "dark");
			}
		</script>
		<script is:inline define:vars={{ isProjectDetailRoute }}>
			try {
				const r = sessionStorage.getItem("routeEnter");
				if (r === "from-home" || r === "from-project") {
					document.documentElement.setAttribute("data-route-enter", r);
					sessionStorage.removeItem("routeEnter");
				}
			} catch (e) {}
			try {
				if (isProjectDetailRoute) {
					/* Slide journal : uniquement si clic prev/next entre fiches (voir transition-nav). Sans le
					 * drapeau `projArticleInterNav`, une `projArticleDir` orpheline déclenchait le slide alors que
					 * `data-route-enter` masquait tout le `.main-shift` → contenu invisible / nav « sans style ». */
					const inter = sessionStorage.getItem("projArticleInterNav") === "1";
					const d = sessionStorage.getItem("projArticleDir");
					if (inter && (d === "prev" || d === "next")) {
						document.documentElement.setAttribute("data-page-slide", d);
					}
				}
			} catch (e) {}
		</script>

		<style is:inline>
			html[data-route-enter="from-home"] .main-shift,
			html[data-route-enter="from-project"] .main-shift {
				opacity: 0;
				visibility: hidden;
			}
			html[data-page-slide="next"] .project-page__journal {
				transform: translate3d(100%, 0, 0);
			}
			html[data-page-slide="prev"] .project-page__journal {
				transform: translate3d(-100%, 0, 0);
			}
		</style>
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<link rel="icon" type="image/svg+xml" href={withBase("favicon.svg")} />
		<meta name="description" content={description} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Exo+2:wght@200;300;400;600&family=Share+Tech+Mono&display=optional"
			rel="stylesheet"
		/>
	</head>
	<body data-route={routePath}>
		{
			isHome ? (
				<canvas
					id="hero-three-canvas"
					class="pointer-events-none fixed inset-0 z-1 block h-full min-h-dvh w-full max-w-none"
					aria-hidden="true"
				/>
			) : null
		}
		<Rail />
		<div class="relative z-10 main-shift">
			<slot />
		</div>
		<script>
			import { boot } from "../scripts/client";
			boot();
		</script>
	</body>
</html>

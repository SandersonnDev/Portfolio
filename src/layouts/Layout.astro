---
import "../styles/icons.css";
import "../styles/app.css";
import { site } from "../site.config";
import Navside from "../components/navside.astro";
import { withBase } from "../lib/paths";

interface Props {
	title?: string;
	description?: string;
}

const { title = `${site.name}`, description = site.pitch } = Astro.props;
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<link rel="icon" type="image/svg+xml" href={withBase("favicon.svg")} />
		<meta name="description" content={description} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Exo+2:wght@200;300;400;600&family=Share+Tech+Mono&display=optional"
			rel="stylesheet"
		/>
	</head>
	<body>
		<Navside />
		<slot />
	</body>
</html>

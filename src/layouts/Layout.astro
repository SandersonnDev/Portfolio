---
import "@fortawesome/fontawesome-free/css/all.min.css";
import "../styles/app.css";
import { ClientRouter, slide } from "astro:transitions";
import { site } from "../site.config";
import Rail from "../components/Rail.astro";
import { withBase } from "../lib/paths";

interface Props {
	title?: string;
	description?: string;
}

const { title = `${site.displayName} · Portfolio`, description = site.pitch } = Astro.props;

const pageSlide = slide({ duration: "400ms" });
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href={withBase("favicon.svg")} />
		<meta name="description" content={description} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Exo+2:wght@200;300;400;600&family=Share+Tech+Mono&display=swap"
			rel="stylesheet"
		/>
		<ClientRouter />
	</head>
	<body>
		<div id="cursor-ring" class="cursor-layer" aria-hidden="true"></div>
		<div id="cursor-dot" class="cursor-layer" aria-hidden="true"></div>
		<canvas id="field-canvas" class="fixed inset-0 z-1 h-full w-full" aria-hidden="true"></canvas>
		<div class="cockpit-scan" aria-hidden="true"></div>
		<div class="cockpit-vignette" aria-hidden="true"></div>
		<Rail />
		<div class="main-shift relative z-10" transition:animate={pageSlide}>
			<slot />
		</div>
		<script>
			import { boot } from "../scripts/client";
			document.addEventListener("astro:page-load", boot);
		</script>
	</body>
</html>

---
import "../styles/icons.css";
import "../styles/app.css";
import { ClientRouter } from "astro:transitions";
import { site } from "../site.config";
import { withBase } from "../lib/paths";
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href={withBase("favicon.svg")} />
		<title>Page introuvable · {site.displayName}</title>
		<ClientRouter />
	</head>
	<body class="font-sans text-(--fg)">
		<main class="flex min-h-dvh flex-col items-center justify-center px-6">
			<p class="font-mono text-xs uppercase tracking-[0.35em] text-(--accent)">404</p>
			<h1 class="mt-4 text-3xl font-normal md:text-4xl">Cette page n’existe pas</h1>
			<p class="mx-auto mt-3 max-w-md text-center leading-relaxed text-(--fg-dim)">
				Le lien est peut-être expiré ou l’URL est incorrecte.
			</p>
			<a href={withBase("")} class="btn-glass mt-10" data-astro-reload>
				<i class="fa-solid fa-house" aria-hidden="true"></i>
				<span>Retour à l’accueil</span>
			</a>
		</main>
	</body>
</html>

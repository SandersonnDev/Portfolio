---
import { copy } from "../site.config";
import { withBase } from "../lib/paths";
interface Neighbor {
    slug: string;
    title: string;
}
interface Props {
    prev: Neighbor | null;
    next: Neighbor | null;
}
const { prev, next } = Astro.props;
const show = prev || next;
---
{
	show ? (
		<nav class="project-article-nav" aria-label={copy.projectNavAria}>
			<div class="project-article-nav__inner">
				<div class="project-article-nav__cell">
					{prev ? (
						<a
							href={withBase(`projets/${prev.slug}`)}
							class="project-article-nav__link project-article-nav__link--prev"
							data-project-nav="prev"
						>
							<span class="project-article-nav__dir sys-mono">
								<i class="fa-solid fa-arrow-left-long" aria-hidden="true" />
								{copy.projectNavPrev}
							</span>
							<span class="project-article-nav__title">{prev.title}</span>
						</a>
					) : (
						<span class="project-article-nav__placeholder" />
					)}
				</div>
				<div class="project-article-nav__cell project-article-nav__cell--end">
					{next ? (
						<a
							href={withBase(`projets/${next.slug}`)}
							class="project-article-nav__link project-article-nav__link--next"
							data-project-nav="next"
						>
							<span class="project-article-nav__dir sys-mono">
								{copy.projectNavNext}
								<i class="fa-solid fa-arrow-right-long" aria-hidden="true" />
							</span>
							<span class="project-article-nav__title">{next.title}</span>
						</a>
					) : (
						<span class="project-article-nav__placeholder" />
					)}
				</div>
			</div>
		</nav>
	) : null
}

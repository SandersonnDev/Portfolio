---
import { site, copy } from "../../site.config";

interface Props {
	githubProfileUrl: string;
	githubUser: string;
}

const { githubProfileUrl, githubUser } = Astro.props;
const abbrLinks = site.lien ?? [];
---

<section
	id="about"
	class="section-viewport relative border-b border-[color-mix(in_srgb,var(--accent)_8%,transparent)]"
	aria-labelledby="ab"
>
	<div
		class="flex min-h-svh flex-col justify-center py-16 ps-[max(1.25rem,env(safe-area-inset-left,0px))] pe-[max(1.25rem,env(safe-area-inset-right,0px))] md:px-12 md:py-20"
	>
		<div class="section-shell min-w-0">
			<h2 id="ab" class="display-heading display-heading--lg" data-rise>
				<span data-scramble data-scramble-final="Section · À propos" class="inline-block min-h-[1.35em]"></span>
			</h2>

			<div class="section-after-h2 grid min-w-0 gap-6 lg:grid-cols-12 lg:gap-8 lg:items-stretch">
				<div
					class="about-block about-block--present flex h-full min-h-0 min-w-0 flex-col lg:col-span-7"
					data-rise
					data-abbr={JSON.stringify(abbrLinks)}
				>
					<div
						class="about-panel flex min-h-full flex-1 flex-col rounded-xl border border-[color-mix(in_srgb,var(--accent)_14%,transparent)] bg-[color-mix(in_srgb,var(--haze)_40%,transparent)] p-6 md:p-8"
					>
						<p class="about-block__label about-block__label--compact">{copy.aboutBlockPresent}</p>
						<div class="about-bio mt-3 space-y-3 leading-relaxed text-(--fg-dim)">
							{
								site.bio.map((text) => (
									<p class="tw-paragraph min-h-13" data-typewriter data-tw-final={text} data-tw-speed="20">
									</p>
								))
							}
						</div>
						{abbrLinks.length > 0 && (
							<div class="about-abbr mt-4 flex w-full flex-col items-center gap-2">
								<p class="about-abbr__label sys-mono mb-0 text-center">Abréviations</p>
								<div class="about-abbr__items flex flex-wrap justify-center gap-2">
									{abbrLinks.map((l, i) => (
										<div class="abbr-item relative inline-flex">
											<a
												href={l.href}
												target="_blank"
												rel="noopener noreferrer"
												class="chip abbr-chip"
												aria-describedby={l.tip ? `abbr-tip-${i}` : undefined}
											>
												<span class="abbr-chip__text">{l.label.replace(/\*$/, "")}</span>
												<i class="fa-solid fa-info abbr-chip__icon" aria-hidden="true"></i>
											</a>
											{l.tip && (
												<span id={`abbr-tip-${i}`} class="abbr-tooltip" role="tooltip">
													{l.tip}
												</span>
											)}
										</div>
									))}
								</div>
							</div>
						)}
					</div>
				</div>

				<div class="flex h-full min-h-0 min-w-0 flex-col gap-4 lg:col-span-5">
					<div
						class="glass glass--panel flex min-h-0 flex-1 flex-col rounded-xl p-6 md:p-8"
						data-rise
					>
						<p class="about-block__label about-block__label--compact mb-0">{copy.aboutBlockStack}</p>
						<div
							id="about-stack-tags"
							class="about-stack-tags about-stack-tags--categorized mt-3 min-h-0 flex-1 space-y-4"
							role="group"
							aria-label="Technologies maîtrisées"
						>
							{
								site.stackByCategory.map((group, gi) => (
									<div class="stack-category" role="group" aria-labelledby={`stack-cat-${gi}`}>
										<p class="stack-category__label" id={`stack-cat-${gi}`}>
											{group.category}
										</p>
										<ul class="stack-category__chips mt-1.5 flex flex-wrap gap-1.5" role="list">
											{group.items.map((s) => (
												<li>
													<span class="chip">
														<i class={s.icon} aria-hidden="true"></i>
														{s.label}
													</span>
												</li>
											))}
										</ul>
									</div>
								))
							}
						</div>
					</div>

					<div
						class="about-contact-panel glass glass--panel shrink-0 rounded-xl p-6 md:p-8"
						data-rise
					>
						<p class="about-block__label about-block__label--compact mb-0">{copy.aboutBlockContact}</p>
						<div class="mt-3 flex flex-col gap-2">
							<a
								href={`mailto:${site.email}`}
								class="btn-sys btn-sys--sm about-contact-link justify-center sm:justify-start"
								title={copy.aboutMailTitle}
								aria-label={copy.aboutMailTitle}
							>
								<i class="fa-regular fa-envelope mr-2" aria-hidden="true"></i>
								{site.email}
							</a>
							<a
								href={githubProfileUrl}
								target="_blank"
								rel="noopener noreferrer"
								class="btn-sys btn-sys--sm justify-center sm:justify-start"
								title={copy.aboutGithubTitle}
								aria-label={copy.aboutGithubTitle}
							>
								<i class="fa-brands fa-github mr-2" aria-hidden="true"></i>
								GitHub · {githubUser}
							</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

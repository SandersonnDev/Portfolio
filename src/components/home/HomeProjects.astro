---
import ProjectGlass from "../ProjectGlass.astro";
import type { GithubProjectCard } from "../../types/github-projects";

interface Props {
	projects: GithubProjectCard[];
}

const { projects } = Astro.props;
---

<section id="projects" class="section-viewport relative" aria-labelledby="pj">
	<div class="projects-pin flex min-h-svh flex-col" data-projects-pin>
		<div
			class="section-head-projects shrink-0 ps-[max(1.25rem,env(safe-area-inset-left,0px))] pe-[max(1.25rem,env(safe-area-inset-right,0px))] md:px-12"
		>
			<div class="section-shell min-w-0">
				<h2 id="pj" class="display-heading display-heading--lg" data-rise>
					<span data-scramble data-scramble-final="Section · Projets" class="inline-block min-h-[1.35em]"></span>
				</h2>
			</div>
		</div>
		<div class="projects-strip-stage relative flex min-h-0 min-w-0 flex-1 flex-col">
			<div class="flex min-h-0 min-w-0 flex-1 items-start justify-start" data-projects-viewport>
				<div
					class="flex w-max min-w-0 items-stretch pe-[max(1.25rem,env(safe-area-inset-right,0px))] will-change-transform md:pr-12"
					data-projects-track
				>
					{projects.map((p, i) => <ProjectGlass {...p} index={i} layout="strip" />)}
					<div
						class="projects-strip__end-spacer shrink-0"
						data-projects-scroll-pad
						aria-hidden="true"
					/>
				</div>
			</div>
			<div
				class="projects-scroll-hint pointer-events-none md:hidden"
				aria-hidden="true"
				title="Faire défiler horizontalement"
			>
				<span class="projects-scroll-hint__icon" aria-hidden="true">
					<i class="fa-solid fa-chevron-right" aria-hidden="true"></i>
				</span>
			</div>
		</div>
	</div>
</section>

---
import type { ReadmeBlock, ReadmeInlinePart, ReadmeTagTableRow } from "../types/readme-blocks";
interface Props {
    blocks: ReadmeBlock[];
}
const { blocks } = Astro.props;
function partsForParagraph(b: Extract<ReadmeBlock, {
    type: "paragraph";
}>): ReadmeInlinePart[] {
    if (b.parts?.length)
        return b.parts;
    if (b.text != null && b.text !== "")
        return [{ k: "text", v: b.text }];
    return [];
}
function tagCardLines(row: ReadmeTagTableRow): {
    top: string;
    bottom: string | null;
} {
    const label = row.label.trim();
    const hint = row.hint.trim();
    if (label && hint && label !== hint)
        return { top: label, bottom: hint };
    if (label)
        return { top: label, bottom: null };
    if (hint)
        return { top: hint, bottom: null };
    return { top: row.href.replace(/^https?:\/\//, "").split("/")[0] || "Lien", bottom: null };
}
---
<div class="readme-content">
	{
		blocks.map((block) => {
			if (block.type === "heading") {
				const Tag = block.level >= 3 ? "h4" : block.level === 2 ? "h3" : "h2";
				return (
					<Tag class:list={["readme-heading", `readme-heading--l${block.level}`]}>{block.text}</Tag>
				);
			}
			if (block.type === "paragraph") {
				const parts = partsForParagraph(block);
				return (
					<p class="readme-p">
						{parts.map((p) =>
							p.k === "bold" ? (
								<strong class="readme-strong">{p.v}</strong>
							) : p.k === "code" ? (
								<code class="readme-code readme-code--inline">{p.v}</code>
							) : (
								<span>{p.v}</span>
							),
						)}
					</p>
				);
			}
			if (block.type === "list") {
				const ListTag = block.ordered ? "ol" : "ul";
				return (
					<ListTag class:list={["readme-list", block.ordered && "readme-list--ordered"]}>
						{block.items.map((itemParts) => (
							<li class="readme-li">
								{itemParts.map((p) =>
									p.k === "bold" ? (
										<strong class="readme-strong">{p.v}</strong>
									) : p.k === "code" ? (
										<code class="readme-code readme-code--inline">{p.v}</code>
									) : (
										<span>{p.v}</span>
									),
								)}
							</li>
						))}
					</ListTag>
				);
			}
			if (block.type === "code") {
				const isMermaid = block.lang?.toLowerCase() === "mermaid";
				if (isMermaid) {
					return (
						<div class="readme-mermaid-wrap">
							<div class="readme-mermaid mermaid">{block.code}</div>
						</div>
					);
				}
				return (
					<div class="readme-pre-wrap" data-lenis-prevent>
						{block.lang ? (
							<p class="readme-pre-label sys-mono">{block.lang}</p>
						) : null}
						<pre class="readme-pre">
							<code>{block.code}</code>
						</pre>
					</div>
				);
			}
			if (block.type === "badgeStrip") {
				const hasOnlyLogo =
					block.items.length === 1 &&
					block.items[0] &&
					!block.items[0].href &&
					/\.(png|jpe?g|gif|webp|svg)(\?|$)/i.test(block.items[0].imgSrc);
				return (
					<div class="readme-badge-strip-wrap">
						<div class="readme-badge-strip">
							{block.items.map((item) =>
								item.href ? (
									<a
										href={item.href}
										target="_blank"
										rel="noopener noreferrer"
										class="readme-badge-strip__link"
									>
										<img
											src={item.imgSrc}
											alt={item.alt}
											class="readme-badge-strip__img"
											loading="lazy"
											decoding="async"
										/>
									</a>
								) : (
									<span class="readme-badge-strip__link">
										<img
											src={item.imgSrc}
											alt={item.alt}
											class:list={[
												"readme-badge-strip__img",
												hasOnlyLogo && "readme-badge-strip__img--logo",
											]}
											loading="lazy"
											decoding="async"
										/>
									</span>
								),
							)}
						</div>
					</div>
				);
			}
			if (block.type === "table") {
				return (
					<div class="readme-table-wrap">
						<div class="readme-table-scroll" data-lenis-prevent>
							<table class="readme-table">
								{block.header?.length ? (
									<thead>
										<tr>
											{block.header.map((parts) => (
												<th scope="col" class="readme-table__th">
													{parts.map((p) =>
														p.k === "bold" ? (
															<strong class="readme-strong">{p.v}</strong>
														) : p.k === "code" ? (
															<code class="readme-code readme-code--inline">{p.v}</code>
														) : (
															<span>{p.v}</span>
														),
													)}
												</th>
											))}
										</tr>
									</thead>
								) : null}
								<tbody>
									{block.rows.map((row) => (
										<tr>
											{row.map((parts) => (
												<td class="readme-table__td">
													{parts.map((p) =>
														p.k === "bold" ? (
															<strong class="readme-strong">{p.v}</strong>
														) : p.k === "code" ? (
															<code class="readme-code readme-code--inline">{p.v}</code>
														) : (
															<span>{p.v}</span>
														),
													)}
												</td>
											))}
										</tr>
									))}
								</tbody>
							</table>
						</div>
					</div>
				);
			}
			if (block.type === "tagTable") {
				return (
					<div class="readme-tag-table-wrap">
						<ul class="readme-tag-table" role="list">
							{block.rows.map((row) => {
								const { top, bottom } = tagCardLines(row);
								return (
									<li class="readme-tag-table__item">
										<a
											href={row.href}
											target="_blank"
											rel="noopener noreferrer"
											class="readme-tag-card"
										>
											<span class="readme-tag-card__primary">{top}</span>
											{bottom ? (
												<span class="readme-tag-card__secondary">{bottom}</span>
											) : null}
										</a>
									</li>
								);
							})}
						</ul>
					</div>
				);
			}
			if (block.type === "rule") {
				return <hr class="readme-hr" />;
			}
			if (block.type === "quote") {
				return (
					<blockquote class="readme-quote">
						{block.parts.map((p) =>
							p.k === "bold" ? (
								<strong class="readme-strong">{p.v}</strong>
							) : p.k === "code" ? (
								<code class="readme-code readme-code--inline">{p.v}</code>
							) : (
								<span>{p.v}</span>
							),
						)}
					</blockquote>
				);
			}
			return null;
		})
	}
</div>

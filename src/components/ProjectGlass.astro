---
import { copy } from "../site.config";
import { withBase } from "../lib/paths";
import { shieldsStackBadgeUrl } from "../lib/shields-badges";

interface Props {
	slug: string;
	title: string;
	description: string;
	href: string;
	index: number;
	/** Topics GitHub ou langages (sync). */
	stack?: string[];
	/** Bandeau horizontal (ScrollTrigger) : pas de `data-rise`. */
	layout?: "grid" | "strip";
}

const { slug, title, description, href, index, stack = [], layout = "grid" } = Astro.props;
const stackBadges = stack.slice(0, 12);
const id = String(index + 1).padStart(2, "0");
const ficheUrl = withBase(`projets/${slug}`);
const strip = layout === "strip";
---

<article
		class:list={[
		"project-card project-card--pad flex h-full flex-col rounded-lg glass glass--panel",
		strip && "project-card--strip",
	]}
	data-rise
	style={`--rise-delay: ${index * 110}ms`}
>
	<header>
		<span class="project-card__meta">OBJ.{id}</span>
		<h3 class="project-card__title">{title}</h3>
		<p class="project-card__lead">{description}</p>
	</header>
	{
		stackBadges.length > 0 && (
			<div
				class="project-card__stack flex flex-wrap"
				role="list"
				aria-label={copy.projectStackBadgesLabel}
			>
				{stackBadges.map((topic) => (
					<span role="listitem" class="project-card__stack-item inline-flex max-w-full">
						<img
							class="project-card__stack-badge max-w-full"
							src={shieldsStackBadgeUrl(topic)}
							alt=""
							height="22"
							loading="lazy"
							decoding="async"
							referrerpolicy="no-referrer-when-downgrade"
						/>
						<span class="sr-only">{topic}</span>
					</span>
				))}
			</div>
		)
	}
	<div class="tile-actions grid grid-cols-1 gap-2 sm:grid-cols-2">
		<a
			href={ficheUrl}
			class="tile-action tile-action--primary"
			title={copy.tileTitleFiche(title)}
			aria-label={copy.tileTitleFiche(title)}
		>
			<i class="tile-action__icon fa-solid fa-file-lines opacity-80" aria-hidden="true"></i>
			{copy.ctaViewFiche}
		</a>
		<a
			href={href}
			target="_blank"
			rel="noopener noreferrer"
			class="tile-action tile-action--secondary"
			title={copy.tileTitleGithub(title)}
			aria-label={copy.tileTitleGithub(title)}
		>
			<i class="tile-action__icon tile-action__icon--git fa-brands fa-github opacity-90" aria-hidden="true"></i>
			{copy.ctaViewSourceFull}
		</a>
	</div>
</article>

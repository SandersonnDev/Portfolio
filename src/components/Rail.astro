---
import { site, copy } from "../site.config";
import { withBase } from "../lib/paths";
import gh from "../data/github-projects.generated.json";

const ghUrl = `https://github.com/${gh.sourceUser}`;
---

<aside class="rail" aria-label={copy.railNavAria}>
	<div class="rail__dock">
		<nav class="rail__cluster">
			<a href={withBase("#hero")} class="rail__link" title={copy.railHome} aria-label={copy.railHome}>
				<i class="fa-solid fa-house" aria-hidden="true"></i>
			</a>
			<a href={withBase("#projects")} class="rail__link" title={copy.railProjects} aria-label={copy.railProjects}>
				<i class="fa-solid fa-list-check" aria-hidden="true"></i>
			</a>
			<a href={withBase("#about")} class="rail__link" title={copy.railAbout} aria-label={copy.railAbout}>
				<i class="fa-solid fa-address-card" aria-hidden="true"></i>
			</a>
		</nav>

		<div class="rail__social" role="group" aria-label="Contact et réseaux">
			<a
				href={ghUrl}
				target="_blank"
				rel="noopener noreferrer"
				class="rail__social-btn"
				title={copy.aboutGithubTitle}
				aria-label={copy.aboutGithubTitle}
			>
				<i class="fa-brands fa-github" aria-hidden="true"></i>
			</a>
			<a
				href={`mailto:${site.email}`}
				class="rail__social-btn"
				title={copy.aboutMailTitle}
				aria-label={copy.aboutMailTitle}
			>
				<i class="fa-regular fa-envelope" aria-hidden="true"></i>
			</a>
		</div>

		<div class="rail__theme" role="group" aria-label={copy.railThemeGroup}>
			<button
				type="button"
				class="rail__social-btn rail__theme-toggle"
				id="rail-theme-toggle"
				data-label-to-light={copy.railThemeToLight}
				data-label-to-dark={copy.railThemeToDark}
				title={copy.railThemeToLight}
				aria-label={copy.railThemeToLight}
			>
				<i class="fa-solid fa-sun rail__theme-icon" aria-hidden="true"></i>
			</button>
		</div>
	</div>
</aside>

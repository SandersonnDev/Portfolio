---
import { work as workEn } from "../site.ENconfig.ts";
import { work as workFr } from "../site.FRconfig.ts";
import I18n from "./I18n.astro";
---

<section
	id="work"
	class="bg-white lg:grid lg:h-screen lg:place-content-center dark:bg-gray-900"
>
	<div class="mx-auto w-screen max-w-7xl px-4 py-16 sm:px-6 sm:py-24 lg:px-8 lg:py-32">
		<div class="mx-auto max-w-prose text-start">
			<h1 class="text-lg font-bold text-gray-900 sm:text-xl dark:text-amber-500 font-mono mb-5">
				<I18n en={workEn.workTitle} fr={workFr.workTitle} block />
			</h1>
		</div>
	</div>
</section>

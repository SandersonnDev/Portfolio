---
/* Direction « back » vers l’accueil + liens /# depuis les fiches projet */
---
<script>
	import { navigate } from "astro:transitions/client";

	function scrollToHashIfPresent() {
		const id = location.hash?.replace(/^#/, "");
		if (!id) return;
		const reduce = window.matchMedia?.("(prefers-reduced-motion: reduce)")?.matches ?? false;
		requestAnimationFrame(() => {
			document.getElementById(id)?.scrollIntoView({
				behavior: reduce ? "auto" : "smooth",
				block: "start",
			});
		});
	}

	/** Toute entrée sur l’accueil depuis une autre page : animation slide « retour » (contenu vient de la gauche). */
	document.addEventListener("astro:before-preparation", (ev) => {
		const from = ev.from?.pathname ?? "";
		const to = ev.to?.pathname ?? "";
		if (to === "/" && from !== "" && from !== "/") {
			ev.direction = "back";
		}
	});

	document.addEventListener(
		"click",
		(e) => {
			if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;

			const el = e.target;
			if (!(el instanceof Element)) return;
			const a = el.closest("a[href]");
			if (!(a instanceof HTMLAnchorElement)) return;
			if (!location.pathname.startsWith("/projets/")) return;

			const url = new URL(a.href, location.href);
			if (url.origin !== location.origin) return;
			if (url.pathname !== "/" && url.pathname !== "") return;
			if (a.hasAttribute("download")) return;
			const t = a.target;
			if (t && t !== "" && t !== "_self") return;

			const hasHash = Boolean(url.hash && url.hash.length > 1);

			if (hasHash) {
				e.preventDefault();
				e.stopPropagation();
				navigate(`${url.pathname}${url.search}${url.hash}`, { history: "replace" });
			}
		},
		true,
	);

	document.addEventListener("astro:page-load", () => {
		if (location.pathname !== "/" || !location.hash) return;
		scrollToHashIfPresent();
	});
</script>

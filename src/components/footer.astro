---
import { site } from "../site.config";
import gh from "../data/github-projects.generated.json";
import { withBase } from "../lib/paths";

const profile = `https://github.com/${gh.sourceUser}`;
const year = new Date().getFullYear();
---

<footer class="border-t border-[color-mix(in_srgb,var(--color-hud)_20%,transparent)] py-12 shadow-[0_-1px_0_color-mix(in_srgb,var(--color-hud)_6%,transparent)]">
	<div class="mx-auto flex max-w-6xl flex-col gap-8 px-5 md:flex-row md:items-center md:justify-between md:px-8">
		<div>
			<p class="font-mono text-[10px] uppercase tracking-[0.28em] text-(--color-muted)">
				© {year} · {site.displayName}
			</p>
			<p class="mt-2 max-w-xs text-xs text-(--color-muted-2)">
				Terminal perso · sync projets GitHub.
			</p>
		</div>
		<div class="flex flex-wrap items-center gap-2">
			<a href={withBase("#hero")} class="btn-tactical btn-tactical--ghost py-2! text-[9px]!">Accueil</a>
			<a href={withBase("#about")} class="btn-tactical btn-tactical--ghost py-2! text-[9px]!">À propos</a>
			<a href={withBase("#projects")} class="btn-tactical btn-tactical--ghost py-2! text-[9px]!">Projets</a>
			<a href={`mailto:${site.email}`} class="btn-tactical btn-tactical--ghost py-2! text-[9px]!">Mail</a>
			<a href={profile} class="btn-tactical py-2! text-[9px]!" target="_blank" rel="noopener noreferrer">
				<i class="fa-brands fa-github" aria-hidden="true"></i>
				{gh.sourceUser}
			</a>
		</div>
	</div>
</footer>

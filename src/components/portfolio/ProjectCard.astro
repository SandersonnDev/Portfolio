---
import type { Project } from "../../data/portfolio";

interface Props {
	project: Project;
	class?: string;
	highlight?: boolean;
	/** Lien pleine carte (molette / clic zone vide) : liens externes restent au-dessus */
	cardLinkOverlay?: boolean;
}

const { project, class: className, highlight, cardLinkOverlay = false } = Astro.props;
---

<article
	class:list={[
		"relative flex h-full min-h-0 flex-col rounded-lg border border-indigo-400/25 bg-zinc-200 p-6 neon-border transition-ui hover:border-indigo-400/45 dark:border-indigo-400/20 dark:bg-zinc-900 dark:hover:border-indigo-400/40",
		highlight &&
			"ring-2 ring-indigo-500/90 ring-offset-2 ring-offset-zinc-100 dark:ring-indigo-400 dark:ring-offset-zinc-950",
		className,
	]}
>
	{
		cardLinkOverlay && (
			<a
				href={`/projets/${project.slug}`}
				class="absolute inset-0 z-[1] rounded-lg focus-visible:z-[5] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-500 dark:focus-visible:outline-indigo-400"
				aria-label={`Voir le projet ${project.title}`}
				data-carousel-card-link
			/>
		)
	}
	<div class:list={[cardLinkOverlay && "pointer-events-none relative z-[2]"]}>
		<h3 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100">{project.title}</h3>
		<p class="mt-2 flex-1 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">{project.description}</p>
		<div class="mt-4 flex flex-wrap gap-2">
			{
				project.stack.map((t) => (
					<span class="rounded border border-indigo-400/30 bg-zinc-300 px-2 py-0.5 text-xs text-indigo-900 dark:border-indigo-400/25 dark:bg-zinc-800 dark:text-indigo-200/95">
						{t}
					</span>
				))
			}
		</div>
		<div class="mt-5 flex flex-wrap gap-3" class:list={[cardLinkOverlay && "pointer-events-auto relative z-[3]"]}>
			{
				cardLinkOverlay ? (
					<span class="inline-flex items-center gap-2 text-sm font-medium text-indigo-700 dark:text-indigo-400">
						<i class="fa-solid fa-circle-info" aria-hidden="true"></i>
						Détails
					</span>
				) : (
					<a
						href={`/projets/${project.slug}`}
						class="transition-ui inline-flex items-center gap-2 text-sm font-medium text-indigo-700 hover:text-indigo-900 dark:text-indigo-400 dark:hover:text-indigo-300"
					>
						<i class="fa-solid fa-circle-info" aria-hidden="true"></i>
						Détails
					</a>
				)
			}
			<a
				href={project.href}
				target="_blank"
				rel="noopener noreferrer"
				class="transition-ui inline-flex items-center gap-2 text-sm font-medium text-zinc-600 hover:text-indigo-700 dark:text-zinc-400 dark:hover:text-indigo-300"
			>
				<i class="fa-brands fa-github" aria-hidden="true"></i>
				Code
			</a>
			{
				project.liveHref && (
					<a
						href={project.liveHref}
						target="_blank"
						rel="noopener noreferrer"
						class="transition-ui text-sm font-medium text-zinc-600 hover:text-indigo-700 dark:text-zinc-400 dark:hover:text-indigo-300"
					>
						Démo
					</a>
				)
			}
		</div>
	</div>
</article>

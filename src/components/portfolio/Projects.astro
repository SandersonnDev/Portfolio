---
import Section from "./Section.astro";
import ProjectCard from "./ProjectCard.astro";
import { projects } from "../../data/portfolio";
---

<Section id="projects" title="Projets" eyebrow="Travaux" reveal revealAnim="right">
	<ul class="grid gap-6 md:grid-cols-2 md:gap-8">
		{
			projects.map((p, i) => {
				const anim = i % 2 === 0 ? "left" : "right";
				return (
					<li
						class="reveal-item min-w-0"
						style={`--reveal-delay: ${i * 165}ms`}
						data-anim={anim}
					>
						<ProjectCard project={p} />
					</li>
				);
			})
		}
	</ul>
</Section>

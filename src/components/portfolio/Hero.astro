---
import { hero, site } from "../../data/portfolio";

const split = Math.min(Math.max(hero.headlineSplit, 0), hero.headline.length);
const headA = hero.headline.slice(0, split);
const headB = hero.headline.slice(split);
---

<section
	class="relative flex min-h-0 min-w-0 flex-col justify-center px-4 pb-16 pt-[calc(5.5rem+env(safe-area-inset-top))] sm:px-6 sm:pb-20 sm:pt-28 md:min-h-[min(88vh,920px)] md:pb-24 lg:px-10 lg:pt-32"
	aria-label="Accueil"
	data-hero-replay
>
	<div class="mx-auto w-full min-w-0 max-w-4xl">
		<h1
		class="hero-bit hero-bit-2 mt-1 select-none text-[clamp(1.65rem,calc(7.2vw_+_0.5rem),5.75rem)] font-bold leading-none sm:text-[clamp(2rem,calc(6.5vw_+_0.25rem),5.75rem)] md:text-[clamp(2.35rem,5.8vw,5.75rem)]"
	>
		<span class="inline-block whitespace-nowrap tracking-[-0.085em]">
			{headA && (
				<>
					<span class="bg-gradient-to-br from-zinc-800 via-zinc-700 to-zinc-600 bg-clip-text text-transparent dark:from-zinc-100 dark:via-zinc-200 dark:to-zinc-500">
						{headA}
					</span>
					<span class="text-indigo-600 drop-shadow-[0_0_32px_rgba(99,102,241,0.25)] dark:text-indigo-400 dark:drop-shadow-[0_0_48px_rgba(129,140,248,0.45)]">
						{headB}
					</span>
				</>
			)}
		</span>
	</h1>
		<p
			class="hero-bit hero-bit-1 mb-3 flex max-w-full flex-wrap items-center gap-x-2 gap-y-1.5 text-xs text-zinc-600 sm:mb-4 sm:text-sm dark:text-zinc-400">
			<span class="inline-flex min-w-0 shrink items-center gap-1.5">
				<i class="fa-solid fa-code shrink-0 text-indigo-600 dark:text-indigo-400" aria-hidden="true"></i>
				<span class="leading-snug">{site.tagline}</span>
			</span>
		</p>
		<div class="hero-bit hero-bit-3 mt-6 flex flex-col gap-2 sm:mt-8 sm:flex-row sm:flex-wrap sm:items-center sm:gap-2.5 md:mt-10 md:gap-3 lg:mt-12">
			<a
				href={hero.ctaPrimary.href}
				class="text-on-indigo-btn neon-border transition-ui inline-flex w-full items-center justify-center rounded-md border border-indigo-500/50 bg-indigo-700 px-5 py-3 text-center text-sm font-medium hover:border-indigo-400/70 hover:bg-indigo-600 dark:border-indigo-400/35 dark:bg-indigo-950 dark:hover:border-indigo-400/55 dark:hover:bg-indigo-900 sm:w-auto sm:py-2.5"
			>
				{hero.ctaPrimary.label}
			</a>
			<a
				href={hero.ctaSecondary.href}
				class="text-on-indigo-btn neon-border transition-ui inline-flex w-full items-center justify-center rounded-md border border-indigo-500/50 bg-indigo-700 px-5 py-3 text-center text-sm font-medium hover:border-indigo-400/70 hover:bg-indigo-600 dark:border-indigo-400/35 dark:bg-indigo-950 dark:hover:border-indigo-400/55 dark:hover:bg-indigo-900 sm:w-auto sm:py-2.5"
			>
				{hero.ctaSecondary.label}
			</a>
			<a
				href={hero.ctaCv.href}
				class="transition-ui inline-flex w-full items-center justify-center gap-2 rounded-md border border-indigo-400/40 bg-transparent px-5 py-3 text-center text-sm font-medium text-indigo-700 hover:border-indigo-500/60 hover:bg-indigo-500/10 dark:border-indigo-400/35 dark:text-indigo-300 dark:hover:border-indigo-400/55 dark:hover:bg-indigo-500/10 sm:w-auto sm:py-2.5"
			>
				<i class="fa-regular fa-file-lines text-base" aria-hidden="true"></i>
				{hero.ctaCv.label}
			</a>
		</div>
	</div>
</section>

---
import Section from "./Section.astro";
import { skillCategories } from "../../data/portfolio";
---

<Section id="stack" title="Stacks" eyebrow="Compétences" reveal revealAnim="left">
	<ul class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3 lg:gap-10">
		{
			skillCategories.map((cat, i) => {
				const anim = i % 3 === 0 ? "left" : i % 3 === 1 ? "up" : "right";
				return (
				<li
					class="reveal-item rounded-lg border border-indigo-400/25 bg-zinc-200 p-6 glow-card transition-ui hover:border-indigo-400/40 dark:border-indigo-400/20 dark:bg-zinc-900 dark:hover:border-indigo-400/35"
					style={`--reveal-delay: ${i * 135}ms`}
					data-anim={anim === "up" ? undefined : anim}
				>
					<h3 class="mb-4 flex items-center gap-2 text-sm font-semibold uppercase tracking-wider text-zinc-800 dark:text-zinc-200">
						<i class={`${cat.icon} text-indigo-600 dark:text-indigo-400`} aria-hidden="true" />
						{cat.label}
					</h3>
					<ul class="space-y-2 text-sm text-zinc-600 dark:text-zinc-400">
						{cat.items.map((item) => (
							<li class="flex items-center gap-2">
								<i class="fa-solid fa-check text-xs text-indigo-600 dark:text-indigo-400/80" aria-hidden="true" />
								{item}
							</li>
						))}
					</ul>
				</li>
				);
			})
		}
	</ul>
</Section>

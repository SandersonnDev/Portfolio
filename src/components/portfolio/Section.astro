---
interface Props {
	id?: string;
	title?: string;
	eyebrow?: string;
	class?: string;
	reveal?: boolean;
	revealAnim?: "up" | "left" | "right" | "zoom";
}

const { id, title, eyebrow, class: className, reveal, revealAnim } = Astro.props;

const hasHeading = Boolean(title || eyebrow);
const staggerHeader = Boolean(reveal && hasHeading);
---

<section
	id={id}
	data-reveal={reveal ? "" : undefined}
	data-reveal-anim={reveal && revealAnim && revealAnim !== "up" ? revealAnim : undefined}
	class:list={["scroll-mt-24 px-4 py-12 sm:px-6 sm:py-14 md:py-16 lg:px-10 lg:py-20", className]}
>
	<div class="mx-auto max-w-3xl lg:max-w-4xl">
		{
			staggerHeader ? (
				<div class="reveal-cascade space-y-10 md:space-y-12">
					<header>
						{eyebrow && (
							<p class="mb-2 text-xs font-semibold uppercase tracking-[0.2em] text-indigo-600 dark:text-indigo-400/90">{eyebrow}</p>
						)}
						{title && (
							<h2 class="text-2xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100 md:text-3xl">{title}</h2>
						)}
					</header>
					<div>
						<slot />
					</div>
				</div>
			) : (
				<>
					{hasHeading && (
						<header class="mb-10 md:mb-12">
							{eyebrow && (
								<p class="mb-2 text-xs font-semibold uppercase tracking-[0.2em] text-indigo-600 dark:text-indigo-400/90">{eyebrow}</p>
							)}
							{title && (
								<h2 class="text-2xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100 md:text-3xl">{title}</h2>
							)}
						</header>
					)}
					<slot />
				</>
			)
		}
	</div>
</section>

---
import { info } from "../site.ENconfig.ts";
import { nav as navEn } from "../site.ENconfig.ts";
import { nav as navFr } from "../site.FRconfig.ts";
import { withBase } from "../lib/paths";
import I18n from "./I18n.astro";

/** Utilitaires Tailwind uniquement. Actif : `.is-active` (`nav-rail.ts`). Variants arbitraires sur la structure du `<a>` (1er span = index, 2e = libellé). */
const navRailLinkClass =
  "group pointer-events-auto flex w-full min-w-0 flex-row items-center justify-start gap-1 whitespace-nowrap rounded-sm font-mono text-sm leading-none tracking-[0.14em] text-(--fg-dim) transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-(--accent) [&.is-active]:text-amber-500 [&.is-active]:[&>span:nth-child(1)>span]:text-amber-500 [&.is-active]:[&>span:nth-child(1)>span]:text-xl [&.is-active]:[&>span:nth-child(2)]:text-amber-500 [&.is-active]:[&>span:nth-child(2)]:font-bold [&.is-active]:[&>span:nth-child(2)]:text-xl";
const navRailIndexPartClass =
  "text-amber-500 transition-colors duration-200 group-hover:text-amber-500 focus-visible:text-amber-500";
const navRailTitleClass =
  "min-w-0 shrink text-left text-sm text-(--fg-dim) transition-colors duration-200 group-hover:text-amber-500 focus-visible:text-amber-500";

const mailAriaEn = `${navEn.buttonEmail} (${info.email})`;
const mailAriaFr = `${navFr.buttonEmail} (${info.email})`;
---

<section>
  <div
    class="pointer-events-none fixed top-10 right-8 z-10 hidden flex-row items-center gap-2.5 lg:flex xl:right-13"
  >
    <div
      id="nav-lang-switch"
      role="group"
      class="pointer-events-auto flex h-6 flex-row items-center gap-0 font-mono text-sm leading-none tracking-[0.14em] [-webkit-tap-highlight-color:transparent]"
      title={navEn.titleSwitchLang}
      data-i18n-title-en={navEn.titleSwitchLang}
      data-i18n-title-fr={navFr.titleSwitchLang}
      aria-label={navEn.titleSwitchLang}
      data-i18n-aria-en={navEn.titleSwitchLang}
      data-i18n-aria-fr={navFr.titleSwitchLang}
    >
      <button
        type="button"
        id="nav-lang-en"
        data-lang-pick="en"
        aria-current="true"
        class="flex h-6 items-center border-0 bg-transparent p-0 text-(--fg-dim) transition-colors [-webkit-tap-highlight-color:transparent] hover:text-amber-500 focus-visible:rounded-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-amber-500 aria-[current=true]:text-amber-500 aria-[current=true]:hover:text-amber-400"
      >
        EN
      </button>
      <span
        class="flex h-6 items-center text-(--fg-dim) opacity-60 select-none"
        aria-hidden="true">|</span
      >
      <button
        type="button"
        id="nav-lang-fr"
        data-lang-pick="fr"
        class="flex h-6 items-center border-0 bg-transparent p-0 text-(--fg-dim) transition-colors [-webkit-tap-highlight-color:transparent] hover:text-amber-500 focus-visible:rounded-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-amber-500 aria-[current=true]:text-amber-500 aria-[current=true]:hover:text-amber-400"
      >
        FR
      </button>
    </div>
    <label
      for="nav-theme-toggle"
      title={navEn.titleSwitchTheme}
      class="pointer-events-auto relative block h-6 w-10 shrink-0 rounded-full bg-gray-300 transition-colors [-webkit-tap-highlight-color:transparent] has-checked:bg-amber-500 dark:bg-gray-600 dark:has-checked:bg-amber-500"
      aria-label={navEn.titleSwitchTheme}
      data-i18n-title-en={navEn.titleSwitchTheme}
      data-i18n-title-fr={navFr.titleSwitchTheme}
      data-i18n-aria-en={navEn.titleSwitchTheme}
      data-i18n-aria-fr={navFr.titleSwitchTheme}
    >
      <input type="checkbox" id="nav-theme-toggle" class="peer sr-only" />
      <span
        class="pointer-events-none absolute inset-y-0 start-0 m-1 size-4 overflow-hidden rounded-full transition-[inset-inline-start] duration-200 motion-safe:transition-[inset-inline-start] peer-checked:start-4 peer-checked:[&_.knob-moon]:opacity-0 peer-checked:[&_.knob-sun]:opacity-100"
        aria-hidden="true"
      >
        <span
          class="pointer-events-none absolute inset-0 grid place-items-center [&>i]:col-start-1 [&>i]:row-start-1 [&>i]:not-italic [&>i]:leading-none"
        >
          <i
            class="knob-moon fa-solid fa-moon text-sm opacity-100 transition-opacity duration-200 dark:text-gray-200"
          ></i>
          <i
            class="knob-sun fa-solid fa-sun text-sm opacity-0 transition-opacity duration-200 dark:text-amber-50"
          ></i>
        </span>
      </span>
    </label>
  </div>
  <div
    class="pointer-events-none fixed bottom-0 right-8 z-10 hidden w-10 flex-col items-center gap-5 after:block after:h-32 after:w-px after:shrink-0 after:bg-(--fg-dim) after:opacity-55 after:content-[''] lg:flex xl:right-10"
  >
    <a
      class="pointer-events-auto flex w-10 shrink-0 flex-col items-center justify-center py-1 text-center font-mono text-sm leading-none tracking-[0.14em] text-(--fg-dim) transition-[color,transform] duration-200 [writing-mode:vertical-rl] hover:text-(--accent) motion-safe:hover:translate-x-0.5 focus-visible:rounded-sm focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-(--accent)"
      href={`mailto:${info.email}`}
      title={navEn.buttonEmail}
      data-i18n-title-en={navEn.buttonEmail}
      data-i18n-title-fr={navFr.buttonEmail}
      data-i18n-aria-en={mailAriaEn}
      data-i18n-aria-fr={mailAriaFr}
      aria-label={mailAriaEn}
    >
      {info.email}
    </a>
  </div>
  <div
    class="pointer-events-none fixed top-10 left-8 z-10 hidden w-auto min-w-10 flex-col items-center gap-2 overflow-visible lg:flex xl:left-13"
  >
    <nav
      id="nav-rail"
      class="flex w-10 min-w-0 flex-col items-stretch self-stretch"
      aria-label={navEn.navAriaMain}
      data-i18n-aria-en={navEn.navAriaMain}
      data-i18n-aria-fr={navFr.navAriaMain}
    >
      <a
        href={withBase("#home")}
        class={navRailLinkClass}
        data-nav-hash="home"
        title={navEn.navHome}
        data-i18n-title-en={navEn.navHome}
        data-i18n-title-fr={navFr.navHome}
        data-i18n-aria-en={navEn.navHome}
        data-i18n-aria-fr={navFr.navHome}
        aria-label={navEn.navHome}
      >
        <span
          class="flex w-10 shrink-0 items-baseline justify-center gap-0"
          aria-hidden="true"
        >
          <span class={navRailIndexPartClass}>01</span>
          <span class={navRailIndexPartClass}>.</span>
        </span>
        <span class={navRailTitleClass} aria-hidden="true">
          <I18n en={navEn.navHome} fr={navFr.navHome} />
        </span>
      </a>
      <span
        class="mb-1 ml-3 mt-1 block h-3 w-px shrink-0 bg-(--fg-dim)"
        aria-hidden="true"></span>
      <a
        href={withBase("#about")}
        class={navRailLinkClass}
        data-nav-hash="about"
        title={navEn.navAbout}
        data-i18n-title-en={navEn.navAbout}
        data-i18n-title-fr={navFr.navAbout}
        data-i18n-aria-en={navEn.navAbout}
        data-i18n-aria-fr={navFr.navAbout}
        aria-label={navEn.navAbout}
      >
        <span
          class="flex w-10 shrink-0 items-baseline justify-center gap-0"
          aria-hidden="true"
        >
          <span class={navRailIndexPartClass}>02</span>
          <span class={navRailIndexPartClass}>.</span>
        </span>
        <span class={navRailTitleClass} aria-hidden="true">
          <I18n en={navEn.navAbout} fr={navFr.navAbout} />
        </span>
      </a>
      <span
        class="mb-1 ml-3 mt-1 block h-3 w-px shrink-0 bg-(--fg-dim)"
        aria-hidden="true"></span>

      <a
        href={withBase("#work")}
        class={navRailLinkClass}
        data-nav-hash="work"
        title={navEn.navWork}
        data-i18n-title-en={navEn.navWork}
        data-i18n-title-fr={navFr.navWork}
        data-i18n-aria-en={navEn.navWork}
        data-i18n-aria-fr={navFr.navWork}
        aria-label={navEn.navWork}
      >
        <span
          class="flex w-10 shrink-0 items-baseline justify-center gap-0"
          aria-hidden="true"
        >
          <span class={navRailIndexPartClass}>03</span>
          <span class={navRailIndexPartClass}>.</span>
        </span>
        <span class={navRailTitleClass} aria-hidden="true">
          <I18n en={navEn.navWork} fr={navFr.navWork} />
        </span>
      </a>
    </nav>
  </div>

  <div
    class="pointer-events-none fixed bottom-0 left-8 z-10 hidden w-auto min-w-10 flex-col items-center gap-2 overflow-visible lg:flex xl:left-10"
  >
    <a
      href={info.githubProfileUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="pointer-events-auto flex size-10 shrink-0 items-center justify-center text-(--fg-dim) transition-[color,transform] duration-200 hover:text-amber-500 motion-safe:hover:-translate-y-0.5"
      title={navEn.buttonGithub}
      data-i18n-title-en={navEn.buttonGithub}
      data-i18n-title-fr={navFr.buttonGithub}
      data-i18n-aria-en={navEn.buttonGithub}
      data-i18n-aria-fr={navFr.buttonGithub}
      aria-label={navEn.buttonGithub}
    >
      <svg
        class="feather feather-github h-6 w-6"
        xmlns="http://www.w3.org/2000/svg"
        role="img"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path
          d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
        ></path>
      </svg>
    </a>
    <a
      href={info.linkedinProfileUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="pointer-events-auto flex size-10 shrink-0 items-center justify-center text-(--fg-dim) transition-[color,transform] duration-200 hover:text-amber-500 motion-safe:hover:-translate-y-0.5"
      title={navEn.buttonLinkedin}
      data-i18n-title-en={navEn.buttonLinkedin}
      data-i18n-title-fr={navFr.buttonLinkedin}
      data-i18n-aria-en={navEn.buttonLinkedin}
      data-i18n-aria-fr={navFr.buttonLinkedin}
      aria-label={navEn.buttonLinkedin}
    >
    <svg
      class="feather feather-linkedin h-6 w-6"
      xmlns="http://www.w3.org/2000/svg"
      role="img"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
    <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
    <rect x="2" y="9" width="4" height="12"></rect>
    <circle cx="4" cy="4" r="2"></circle>
    </svg>
  </a>
    </a>
    <span
      class="block h-32 w-px shrink-0 bg-(--fg-dim) opacity-55"
      aria-hidden="true"></span>
  </div>
</section>
